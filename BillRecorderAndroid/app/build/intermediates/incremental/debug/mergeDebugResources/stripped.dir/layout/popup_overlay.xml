<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg"
    android:padding="16dp"
    android:elevation="12dp">

    <!-- Header row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="💳  New Transaction"
            android:textColor="#F1E3A1" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvClose" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="✕"
            android:textColor="#888888" android:textSize="16sp" android:padding="4dp"/>
    </LinearLayout>

    <!-- Amount display (read-only) -->
    <TextView android:id="@+id/tvPopupAmount"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="-S$25.00" android:textColor="#E26C59"
        android:textSize="28sp" android:textStyle="bold"
        android:layout_marginBottom="14dp"/>

    <!-- Editable Label (transaction title) -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="LABEL" android:textColor="#888888"
        android:textSize="10sp" android:letterSpacing="0.1"
        android:layout_marginBottom="2dp"/>
    <EditText android:id="@+id/etPopupLabel"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="e.g. Coffee at Starbucks"
        android:textColor="#FFFFFF" android:textColorHint="#666666"
        android:textSize="14sp" android:padding="8dp"
        android:background="@drawable/input_bg"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginBottom="10dp"/>

    <!-- Editable Description / Note -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="DESCRIPTION" android:textColor="#888888"
        android:textSize="10sp" android:letterSpacing="0.1"
        android:layout_marginBottom="2dp"/>
    <EditText android:id="@+id/etPopupNote"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Optional note..."
        android:textColor="#FFFFFF" android:textColorHint="#666666"
        android:textSize="14sp" android:padding="8dp"
        android:background="@drawable/input_bg"
        android:inputType="textMultiLine"
        android:minLines="2" android:maxLines="3"
        android:layout_marginBottom="14dp"/>

    <!-- Action Buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnPopupDiscard"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Discard"
            android:textColor="#888888" android:textSize="13sp"
            android:backgroundTint="@android:color/transparent"
            android:layout_marginEnd="6dp"/>
        <Button android:id="@+id/btnPopupSave"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Save"
            android:textColor="#403F3B" android:textSize="13sp"
            android:backgroundTint="#F1E3A1"/>
    </LinearLayout>

</LinearLayout>
