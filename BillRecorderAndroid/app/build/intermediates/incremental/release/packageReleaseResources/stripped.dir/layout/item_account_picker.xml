<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:paddingHorizontal="16dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <!-- Card Icon / Visa Logo -->
    <LinearLayout
        android:id="@+id/llAccIconContainer"
        android:layout_width="56dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/ic_visa_card"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VISA"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Account Name -->
    <TextView
        android:id="@+id/tvAccName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/llAccIconContainer"
        android:layout_marginStart="16dp"
        android:layout_centerVertical="true"
        android:text="ocbc"
        android:textColor="@color/textPrimary"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <!-- Balance -->
    <TextView
        android:id="@+id/tvAccBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="S$11,524.59"
        android:textColor="@color/incomeGreen"
        android:textSize="15sp"
        android:textStyle="bold"/>

</RelativeLayout>
