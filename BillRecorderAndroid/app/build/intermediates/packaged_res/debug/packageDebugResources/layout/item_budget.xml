<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp"
    android:gravity="center_vertical">

    <androidx.cardview.widget.CardView android:id="@+id/cvIcon"
        android:layout_width="44dp" android:layout_height="44dp"
        app:cardCornerRadius="22dp" app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">
        <ImageView android:id="@+id/ivIcon" android:layout_width="match_parent"
            android:layout_height="match_parent" android:scaleType="fitCenter"
            android:visibility="gone"/>
        <TextView android:id="@+id/tvIcon" android:layout_width="match_parent"
            android:layout_height="match_parent" android:gravity="center" android:textSize="20sp"/>
    </androidx.cardview.widget.CardView>

    <!-- Name + current budget amount stacked -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvCatName" android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary" android:textSize="17sp"/>
        <TextView android:id="@+id/tvCurrentBudget" android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/textPrimary" android:textSize="20sp"
            android:textStyle="bold" android:layout_marginTop="2dp"
            android:visibility="gone"/>
    </LinearLayout>

    <Button android:id="@+id/btnSetBudget" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="SET BUDGET"
        android:textColor="@color/textPrimary" android:textSize="12sp"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:backgroundTint="@android:color/transparent"
        android:background="@drawable/btn_outline_drawable"
        android:paddingHorizontal="14dp" android:paddingVertical="8dp"/>
</LinearLayout>
