<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:gravity="center_vertical">

    <androidx.cardview.widget.CardView android:id="@+id/cvIcon"
        android:layout_width="40dp" android:layout_height="40dp"
        app:cardCornerRadius="20dp" app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">
        <ImageView android:id="@+id/ivIcon" android:layout_width="match_parent"
            android:layout_height="match_parent" android:scaleType="fitCenter"
            android:visibility="gone"/>
        <TextView android:id="@+id/tvIcon" android:layout_width="match_parent"
            android:layout_height="match_parent" android:gravity="center" android:textSize="18sp"/>
    </androidx.cardview.widget.CardView>

    <TextView android:id="@+id/tvCatName" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="@color/textSecondary" android:textSize="16sp"
        android:layout_marginStart="12dp"/>

    <TextView android:id="@+id/tvMenu" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="···" android:textColor="@color/textSecondary" android:textSize="20sp" android:padding="8dp"/>
</LinearLayout>
