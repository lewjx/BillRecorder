<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="390dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg"
    android:padding="20dp"
    android:elevation="12dp">

    <!-- Header row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="14dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="💳  New Transaction"
            android:textColor="#F1E3A1" android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvClose" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="✕"
            android:textColor="#888888" android:textSize="18sp" android:padding="6dp"/>
    </LinearLayout>

    <!-- Income / Expense badge -->
    <TextView android:id="@+id/tvTypeBadge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="EXPENSE" android:textColor="#FFFFFF"
        android:textSize="11sp" android:textStyle="bold"
        android:paddingHorizontal="10dp" android:paddingVertical="3dp"
        android:background="@drawable/btn_outline_drawable"
        android:layout_marginBottom="8dp"/>

    <!-- Amount display (read-only) -->
    <TextView android:id="@+id/tvPopupAmount"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="-S$25.00" android:textColor="#E26C59"
        android:textSize="36sp" android:textStyle="bold"
        android:layout_marginBottom="18dp"/>

    <!-- Editable Label -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="LABEL" android:textColor="#888888"
        android:textSize="11sp" android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etPopupLabel"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="e.g. Coffee at Starbucks"
        android:textColor="#FFFFFF" android:textColorHint="#666666"
        android:textSize="16sp" android:padding="10dp"
        android:background="@drawable/input_bg"
        android:inputType="text" android:maxLines="1"
        android:layout_marginBottom="12dp"/>

    <!-- Editable Description / Note -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="DESCRIPTION" android:textColor="#888888"
        android:textSize="11sp" android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etPopupNote"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Optional note..."
        android:textColor="#FFFFFF" android:textColorHint="#666666"
        android:textSize="16sp" android:padding="10dp"
        android:background="@drawable/input_bg"
        android:inputType="textMultiLine"
        android:minLines="2" android:maxLines="3"
        android:layout_marginBottom="16dp"/>

    <!-- Action Buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnPopupDiscard"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="Discard"
            android:textColor="#888888" android:textSize="15sp"
            android:backgroundTint="@android:color/transparent"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnPopupSave"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="Save"
            android:textColor="#403F3B" android:textSize="15sp"
            android:backgroundTint="#F1E3A1"/>
    </LinearLayout>

</LinearLayout>
